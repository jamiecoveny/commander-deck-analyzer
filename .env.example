# Commander Deck Analyzer — environment variables
# Copy to .env and fill in.

# --- Database ---
# SQLite (default local dev — zero setup):
DATABASE_URL="file:./dev.db"
# Postgres (production) — also switch the provider in prisma/schema.prisma:
# DATABASE_URL="postgresql://user:password@localhost:5432/cda?schema=public"

# --- Sim service ---
# Base URL of the FastAPI playtest simulator. Defaults to localhost in dev.
SIM_SERVICE_URL="http://localhost:8001"

# --- Cache ---
# Optional Upstash/Redis URL. Leave blank to fall back to in-memory cache.
REDIS_URL=""

# --- Identification for outbound HTTP ---
# Polite User-Agent for Scryfall, EDHrec, Spellbook, Face à Face.
# Replace the email with a real contact before any production deploy.
HTTP_USER_AGENT="commander-deck-analyzer/0.1 (contact: you@example.com)"

# --- Auth (Phase 3) ---
# NEXTAUTH_URL=""
# NEXTAUTH_SECRET=""
# EMAIL_SERVER=""
# EMAIL_FROM=""
